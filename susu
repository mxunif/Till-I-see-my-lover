<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>For My Susu ❤️</title>

<style>
*{
    box-sizing:border-box;
    font-family:'Segoe UI', sans-serif;
}

body{
    margin:0;
    min-height:100vh;
    background:linear-gradient(135deg,#ff9a9e,#fad0c4);
    color:white;
    text-align:center;
    overflow-x:hidden;
}

.container{
    width:90%;
    max-width:500px;
    margin:auto;
    padding:30px;
}

.card{
    background:rgba(255,255,255,0.2);
    backdrop-filter:blur(10px);
    border-radius:25px;
    padding:25px;
    margin:25px 0;
    box-shadow:0 0 25px rgba(0,0,0,.15);
}

h1{
    font-size:40px;
}

h2{
    font-size:28px;
}

button{
    border:none;
    padding:15px 25px;
    border-radius:30px;
    background:#ff4f81;
    color:white;
    font-size:18px;
    cursor:pointer;
    margin:10px;
}

button:hover{
    transform:scale(1.08);
}

input{
    padding:12px;
    border-radius:20px;
    border:none;
    text-align:center;
    font-size:18px;
}

.hidden{
    display:none;
}


/* FLAGS */

.flags{
    display:flex;
    justify-content:center;
    gap:30px;
    margin:20px;
}

.flag{
    width:90px;
    height:60px;
    border-radius:8px;
    overflow:hidden;
    border:2px solid white;
}


/* Benin */

.benin{
    display:flex;
}

.benin .green{
    width:33%;
    background:#008751;
}

.benin .right{
    width:67%;
}

.benin .yellow{
    height:50%;
    background:#FCD116;
}

.benin .red{
    height:50%;
    background:#E8112D;
}


/* Syria */

.syria div{
    height:33.33%;
}

.syria .red{
    background:#CE1126;
}

.syria .white{
    background:white;
    color:#000;
    display:flex;
    align-items:center;
    justify-content:center;
}

.syria .black{
    background:#000;
}

.stars{
    color:#008000;
    font-size:20px;
}


/* hearts */

.heart{
    position:fixed;
    animation:fall linear infinite;
}

@keyframes fall{
    from{
        transform:translateY(-10vh);
    }
    to{
        transform:translateY(110vh);
    }
}


.distance{
    font-size:20px;
    line-height:2;
}


.message{
    font-size:22px;
    min-height:80px;
}


</style>

</head>

<body>


<div class="container">


<div class="card" id="lock">

<h1>For My Susu ❤️</h1>

<p>
Every day apart has only made me love you more.
</p>

<h3>
What date did our story begin?
</h3>

<input id="password" placeholder="DD/MM/YY">

<br>

<button onclick="unlock()">
Open My Heart ❤️
</button>

<p id="wrong"></p>

</div>



<div id="website" class="hidden">


<div class="card">

<h1>
My Beautiful Sara ❤️
</h1>

<p>
If you're reading this...
</p>

<p>
This is a little piece of my heart while I wait to see you again.
</p>


<div class="flags">


<div>

<p>🇧🇯</p>

<div class="flag benin">

<div class="green"></div>

<div class="right">
<div class="yellow"></div>
<div class="red"></div>
</div>

</div>

</div>



<div>

<p>🇸🇾</p>

<div class="flag syria">

<div class="red"></div>

<div class="white">
<span class="stars">
★ ★
</span>
</div>

<div class="black"></div>

</div>

</div>


</div>


</div>




<div class="card">


<h2>
🌍 Distance Between Us
</h2>


<div class="distance">

❤️ 2,229 miles

<br>

❤️ 3,587 kilometres

<br>

❤️ 3,587,000 metres


<br><br>


🇧🇯 That is about <b>5.1 Benin lengths</b>

<br>

🇸🇾 That is about <b>2 Aleppo-sized distances</b>


</div>


<p>
No matter how far we are...
my heart is always close to yours ❤️
</p>


</div>




<div class="card">


<h2>
⏳ Until I Hold You Again
</h2>


<h1 id="countdown">
Loading...
</h1>


</div>




<div class="card">


<h2>
💌 Today's Message
</h2>


<div class="message" id="dailyMessage">

Loading...

</div>


</div>
<script>


function unlock(){

let password=document.getElementById("password").value;

if(password==="25/05/25"){

document.getElementById("lock").style.display="none";
document.getElementById("website").style.display="block";

startHearts();

}

else{

document.getElementById("wrong").innerHTML=
"Only my favourite girl knows this one 🤍";

}

}





// Countdown to reunion

let reunionDate = new Date("September 4, 2026 00:00:00").getTime();


setInterval(function(){

let now=new Date().getTime();

let distance=reunionDate-now;


let days=Math.floor(distance/(1000*60*60*24));

let hours=Math.floor((distance%(1000*60*60*24))/(1000*60*60));

let minutes=Math.floor((distance%(1000*60*60))/(1000*60));

let seconds=Math.floor((distance%(1000*60))/1000);



document.getElementById("countdown").innerHTML=
days+" Days<br>"+
hours+" Hours<br>"+
minutes+" Minutes<br>"+
seconds+" Seconds";


},1000);






// 67 reasons

const messages=[

"I miss your smell.",

