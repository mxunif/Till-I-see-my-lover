// count days from 27 June

let startDate=new Date("June 27, 2026").getTime();


function updateMessage(){

let today=new Date().getTime();


let day=Math.floor(
(today-startDate)/(1000*60*60*24)
);


if(day<0){
day=0;
}


if(day>=messages.length){
day=messages.length-1;
}


document.getElementById("dailyMessage").innerHTML=

"Day "+(day+1)+" ❤️<br><br>"+
messages[day];

}


updateMessage();






// floating hearts

function startHearts(){

setInterval(()=>{


let heart=document.createElement("div");

heart.className="heart";

heart.innerHTML="❤️";

heart.style.left=Math.random()*100+"%";

heart.style.fontSize=(15+Math.random()*25)+"px";

heart.style.animationDuration=
(3+Math.random()*5)+"s";


document.body.appendChild(heart);


setTimeout(()=>{

heart.remove();

},8000);


},300);


}





</script>




<div class="card">


<h2>
💌 A Little Surprise
</h2>


<p>

The biggest gift isn't something wrapped...

</p>


<p>

It's finally having you close again.

</p>


<p>

I can't wait to have you in my arms,
hold you tight,
and make more beautiful memories together ❤️

</p>


</div>




<div class="card">


<h2>
🌙 Same Moon
</h2>


<p>

Even when thousands of miles separate us...

</p>


<p>

we are still looking at the same moon.

</p>


<p>

Until I see you again, my Susu ❤️

</p>


</div>



</div>

</div>


</body>
</html>
